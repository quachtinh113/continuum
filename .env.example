# ============================================
# NowTrading 2.0 - Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- MT5 Credentials ---
MT5_ACCOUNT=206539306
MT5_PASSWORD=your_password_here
MT5_SERVER=Exness-MT5Trial7
MT5_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe

# --- Trading Mode ---
# false = DRY_RUN (paper trading, no real orders)
# true  = LIVE (real orders on MT5)
LIVE_TRADING=false

# --- Risk Parameters ---
MAX_LOT_SIZE=0.01
MAX_DCA_LAYERS=3
MAX_DAILY_DRAWDOWN_USD=50
MAX_ACTIVE_CYCLES=5
PROFIT_TARGET_USD=5

# --- Indicator Parameters ---
RSI_PERIOD=14
RSI_BUY_THRESHOLD=55
RSI_SELL_THRESHOLD=45
RSI_PULLBACK_THRESHOLD=50
ADX_PERIOD=14
ADX_RANGE_THRESHOLD=18
ADX_TREND_THRESHOLD=25
ATR_PERIOD=14

# --- DCA Parameters ---
DCA_LAYER_1_ATR=1.0
DCA_LAYER_2_ATR=1.5
DCA_LAYER_3_ATR=2.0

# --- Strategy Parameters ---
PULLBACK_LOOKBACK_BARS=5
EMERGENCY_EVENT_MODE=false
MAX_TICK_AGE_SECONDS=120

# --- Time Rules ---
HOLDING_REDUCE_HOURS=12
HOLDING_MAX_HOURS=24
HOURLY_GATE_WINDOW_MINUTES=5

# --- Spread Limits (pips for FX, points for indices) ---
SPREAD_LIMIT_FX=5
SPREAD_LIMIT_INDEX=500
SPREAD_LIMIT_GOLD=50
SPREAD_LIMIT_CRYPTO=2000

# --- Logging ---
LOG_DIR=logs
LOG_LEVEL=INFO
